# ========================================
# Configuration Laragon — PostgreSQL local
# ========================================
# Ce fichier est la source. Pour l'activer :
#   npm run laragon:setup
# ou manuellement :
#   copy .env.laragon .env.local
# Le fichier .env.local est chargé automatiquement par Next.js.

DATABASE_URL="postgresql://postgres:@localhost:5432/flexwork?schema=public"

NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-to-a-random-secret-in-production"

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxxxxxxx"
STRIPE_SECRET_KEY="sk_test_xxxxxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxx"

TRUSTENGINE_API_KEY="te_xxxxxxxx"
TRUSTENGINE_WEBHOOK_SECRET="te_whsec_xxxxxxxx"

REDIS_URL="redis://localhost:6379"

SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Flexwork <noreply@flexwork.app>"
SMTP_SECURE="false"

OPENAI_API_KEY="sk-xxxxxxxx"

# Notifications (Mailpit en dev — Web UI: http://localhost:8025)
NOTIFY_CLIENT_EMAIL="client@flexwork.test"
NOTIFY_FREELANCER_EMAIL="freelance@flexwork.test"
NOTIFY_ADMIN_EMAIL="admin@flexwork.test"
