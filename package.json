{
  "name": "flexwork",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "npx prisma db push",
    "db:seed": "npx prisma db seed",
    "seed": "npx prisma db seed",
    "workers": "npx tsx lib/workers.ts",
    "ws": "npx tsx server/ws-server.ts",
    "mailpit": "docker run -d --rm -p 1025:1025 -p 8025:8025 axllent/mailpit",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "setup": "npm run docker:up && npm run db:push && npm run db:seed",
    "simulate": "npx tsx scripts/simulate.ts",
    "turn": "node scripts/turn-server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "laragon:setup": "copy .env.laragon .env.local /Y && npx prisma db push && npx prisma db seed",
    "dev:all": "concurrently \"npm run docker:up\" \"next dev\" \"npx tsx lib/workers.ts\" \"npx tsx server/ws-server.ts\""
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@bull-board/api": "^8.0.0",
    "@bull-board/ui": "^8.0.0",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.78.1",
    "clsx": "^2.1.1",
    "ioredis": "^5.11.1",
    "lucide-react": "^1.23.0",
    "next": "14.2.35",
    "next-auth": "^4.24.14",
    "next-intl": "^4.13.0",
    "nodemailer": "^7.0.13",
    "prisma": "^5.22.0",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.79.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "25.9.3",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "jsdom": "^29.1.1",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
